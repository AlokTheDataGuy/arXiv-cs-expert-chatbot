// Visualization of: Binary Tree
digraph {
	root [label=Root]
	left [label="Left Child"]
	right [label="Right Child"]
	left_left [label="Left Left"]
	left_right [label="Left Right"]
	right_left [label="Right Left"]
	right_right [label="Right Right"]
	root -> left
	root -> right
	left -> left_left
	left -> left_right
	right -> right_left
	right -> right_right
}
